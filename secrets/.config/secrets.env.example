# Copy this file to ~/.config/secrets.env and fill in real values.
# ~/.config/secrets.env is git-ignored and sourced by ~/.zshrc.
# Regenerate/rotate any token that ever landed in a committed file.

# GitHub personal access token (classic). Create at https://github.com/settings/tokens
export GITHUB_TOKEN=""

# Slack (used by ~/.config/slack/slack.sh). Pull from a logged-in Slack web session.
export SLACK_TOKEN=""
export SLACK_COOKIE=""
export SLACK_USER_ID=""
