{
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "go_to_definition_fallback": "none",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "title_bar": {
    "show_branch_status_icon": true,
  },
  "agent_servers": {
    "claude-acp": {
      "default_config_options": {
        "fast": "off",
        "effort": "xhigh",
        "mode": "auto",
        "model": "opus[1m]",
      },
      "type": "registry",
    },
  },
  "context_servers": {
    "chrome-devtools": {
      "enabled": true,
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"],
    },
  },
  "git_panel": {
    "dock": "left",
    "status_style": "icon",
    "diff_stats": true,
    "show_count_badge": false,
    "collapse_untracked_diff": false,
    "file_icons": false,
    "tree_view": false,
    "sort_by": "path",
  },
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle",
  },
  "agent": {
    "max_content_width": 1200.0,
    "default_width": 640.0,
    "sidebar_side": "right",
    "dock": "right",
    "show_turn_stats": true,
    "play_sound_when_agent_done": "when_hidden",
    "favorite_models": [],
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6",
      "enable_thinking": false,
    },
    "model_parameters": [],
  },
  "buffer_font_size": 15,
  "buffer_font_features": {
    "calt": true,
    "liga": true,
    "dlig": true,
    "ss01": true,
    "ss02": true,
    "ss03": true,
  },
  "buffer_font_weight": 400,
  "buffer_font_family": "Fira Code",
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "seed_search_query_from_cursor": "selection",
  "tab_size": 2,
  "theme": {
    "mode": "dark",
    "light": "Zedokai Light",
    "dark": "Zedokai Darker",
  },
  "toolbar": {
    "quick_actions": false,
    "selections_menu": false,
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
  },
  "lsp": {
    "wakatime": {
      "initialization_options": {
        "api-key": "waka_REPLACE_ME",
      },
    },
    "oxlint": {
      "initialization_options": {
        "settings": {
          "run": "onType",
        },
      },
    },
    "oxfmt": {
      "initialization_options": {
        "settings": {
          "run": "onSave",
        },
      },
    },
  },
  "languages": {
    "Elm": {
      "tab_size": 4,
    },
    "JavaScript": {
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "TypeScript": {
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "TSX": {
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "JSON": {
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "YAML": {
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "Markdown": {
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "CSS": {
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "HTML": {
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
  },
  "wrap_guides": [80, 100, 120],
  "experimental.theme_overrides": {},
}
